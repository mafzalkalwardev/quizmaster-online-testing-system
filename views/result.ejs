<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Result - QuizMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <h1>📚 QuizMaster</h1>
            </div>
            <ul class="nav-menu">
                <li><a href="/">Home</a></li>
                <li><a href="/dashboard">Dashboard</a></li>
                <li><a href="/quizzes">Quizzes</a></li>
                <li><span class="user-name">Hello, <%= user.name %></span></li>
                <li><a href="/logout" class="logout-btn">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <section class="result-section">
            <div class="result-card">
                <div class="result-header">
                    <h1>Quiz Completed! 🎉</h1>
                    <p class="result-subtitle"><%= result.quizTitle %></p>
                </div>

                <div class="result-body">
                    <div class="score-display">
                        <div class="score-circle">
                            <div class="score-value"><%= result.percentage.toFixed(2) %>%</div>
                            <div class="score-label">Score</div>
                        </div>
                    </div>

                    <div class="result-details">
                        <div class="detail-row">
                            <span class="detail-label">Marks Obtained:</span>
                            <span class="detail-value"><%= result.score %> / <%= result.totalMarks %></span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Percentage:</span>
                            <span class="detail-value"><%= result.percentage.toFixed(2) %>%</span>
                        </div>
                        <div class="detail-row">
                            <span class="detail-label">Submitted At:</span>
                            <span class="detail-value"><%= new Date(result.submittedAt).toLocaleString() %></span>
                        </div>
                    </div>

                    <div class="result-status">
                        <% if (result.percentage >= 80) { %>
                            <div class="status excellent">✓ Excellent Performance!</div>
                        <% } else if (result.percentage >= 60) { %>
                            <div class="status good">✓ Good Performance!</div>
                        <% } else if (result.percentage >= 40) { %>
                            <div class="status fair">○ Fair Performance</div>
                        <% } else { %>
                            <div class="status poor">✗ Need Improvement</div>
                        <% } %>
                    </div>
                </div>

                <div class="result-actions">
                    <a href="/quizzes" class="btn btn-primary">Browse More Quizzes</a>
                    <a href="/my-results" class="btn btn-secondary">View All Results</a>
                    <a href="/dashboard" class="btn btn-secondary">Go to Dashboard</a>
                </div>
            </div>
        </section>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 QuizMaster. Online Testing System</p>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
