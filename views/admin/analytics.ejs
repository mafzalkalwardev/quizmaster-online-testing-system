<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Analytics - QuizMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <h1>📚 QuizMaster Admin</h1>
            </div>
            <ul class="nav-menu">
                <li><a href="/admin/dashboard">Dashboard</a></li>
                <li><a href="/admin/analytics">Analytics</a></li>
                <li><span class="user-name">Admin: <%= user.name %></span></li>
                <li><a href="/logout" class="logout-btn">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <section class="analytics-section">
            <a href="/admin/dashboard" class="btn btn-secondary">← Back to Dashboard</a>

            <h1>System Analytics</h1>

            <div class="analytics-grid">
                <!-- Attempts per Quiz -->
                <div class="analytics-card">
                    <h2>Attempts Per Quiz</h2>
                    <% if (attemptsPerQuiz.length === 0) { %>
                        <p>No data available</p>
                    <% } else { %>
                        <table class="analytics-table">
                            <thead>
                                <tr>
                                    <th>Quiz Title</th>
                                    <th>Attempts</th>
                                    <th>Avg Score</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% attemptsPerQuiz.forEach(item => { %>
                                    <tr>
                                        <td><%= item._id %></td>
                                        <td><%= item.attemptCount %></td>
                                        <td><%= item.averageScore.toFixed(2) %>%</td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>

                <!-- Top Students -->
                <div class="analytics-card">
                    <h2>Top Performing Students</h2>
                    <% if (topStudents.length === 0) { %>
                        <p>No data available</p>
                    <% } else { %>
                        <table class="analytics-table">
                            <thead>
                                <tr>
                                    <th>Student</th>
                                    <th>Avg Score</th>
                                    <th>Attempts</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% topStudents.forEach(student => { %>
                                    <tr>
                                        <td><%= student._id %></td>
                                        <td><%= student.averageScore.toFixed(2) %>%</td>
                                        <td><%= student.totalAttempts %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>

                <!-- Score Distribution -->
                <div class="analytics-card">
                    <h2>Score Distribution</h2>
                    <% if (scoreDistribution.length === 0) { %>
                        <p>No data available</p>
                    <% } else { %>
                        <table class="analytics-table">
                            <thead>
                                <tr>
                                    <th>Score Range</th>
                                    <th>Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% scoreDistribution.forEach(dist => { %>
                                    <tr>
                                        <td><%= dist._id %>%</td>
                                        <td><%= dist.count %></td>
                                    </tr>
                                <% }); %>
                            </tbody>
                        </table>
                    <% } %>
                </div>
            </div>
        </section>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 QuizMaster. Online Testing System</p>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
