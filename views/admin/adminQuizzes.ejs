<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Manage Quizzes - QuizMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <h1>📚 QuizMaster Admin</h1>
            </div>
            <ul class="nav-menu">
                <li><a href="/admin/dashboard">Dashboard</a></li>
                <li><a href="/admin/quizzes">Quizzes</a></li>
                <li><span class="user-name">Admin: <%= user.name %></span></li>
                <li><a href="/logout" class="logout-btn">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <section class="quizzes-management">
            <a href="/admin/dashboard" class="btn btn-secondary">← Back to Dashboard</a>

            <h1>Manage Quizzes</h1>

            <div class="create-btn">
                <a href="/quizzes/admin/create" class="btn btn-primary">➕ Create New Quiz</a>
            </div>

            <% if (quizzes.length === 0) { %>
                <div class="empty-state">
                    <p>No quizzes created yet. <a href="/quizzes/admin/create">Create the first quiz</a></p>
                </div>
            <% } else { %>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Quiz Title</th>
                                <th>Category</th>
                                <th>Difficulty</th>
                                <th>Marks</th>
                                <th>Time Limit</th>
                                <th>Created By</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% quizzes.forEach(quiz => { %>
                                <tr>
                                    <td><%= quiz.title %></td>
                                    <td><%= quiz.category %></td>
                                    <td><%= quiz.difficulty %></td>
                                    <td><%= quiz.totalMarks %></td>
                                    <td><%= quiz.timeLimit %> min</td>
                                    <td><%= quiz.createdBy.name %></td>
                                    <td>
                                        <a href="/questions/quiz/<%= quiz._id %>/questions" class="btn btn-info btn-sm">Questions</a>
                                        <a href="/quizzes/admin/<%= quiz._id %>/edit" class="btn btn-secondary btn-sm">Edit</a>
                                        <button class="btn btn-danger btn-sm" onclick="deleteQuiz('<%= quiz._id %>')">Delete</button>
                                    </td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 QuizMaster. Online Testing System</p>
    </footer>

    <script src="/js/main.js"></script>
    <script>
        function deleteQuiz(quizId) {
            if (confirm('Are you sure you want to delete this quiz? All questions will be deleted too.')) {
                fetch(`/quizzes/admin/${quizId}/delete`, {
                    method: 'DELETE'
                })
                .then(res => res.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error deleting quiz');
                    }
                });
            }
        }
    </script>
</body>
</html>
