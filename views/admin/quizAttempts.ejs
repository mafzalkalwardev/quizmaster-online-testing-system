<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Quiz Attempts - QuizMaster</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <h1>📚 QuizMaster Admin</h1>
            </div>
            <ul class="nav-menu">
                <li><a href="/admin/dashboard">Dashboard</a></li>
                <li><a href="/admin/quizzes">Quizzes</a></li>
                <li><span class="user-name">Admin: <%= user.name %></span></li>
                <li><a href="/logout" class="logout-btn">Logout</a></li>
            </ul>
        </div>
    </nav>

    <div class="container">
        <section class="attempts-section">
            <a href="/admin/quizzes" class="btn btn-secondary">← Back to Quizzes</a>

            <h1>Attempts for: <%= quiz.title %></h1>

            <% if (attempts.length === 0) { %>
                <div class="empty-state">
                    <p>No student has attempted this quiz yet.</p>
                </div>
            <% } else { %>
                <div class="table-wrapper">
                    <table class="admin-table">
                        <thead>
                            <tr>
                                <th>Student Name</th>
                                <th>Score</th>
                                <th>Total Marks</th>
                                <th>Percentage</th>
                                <th>Submitted At</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% attempts.forEach(attempt => { %>
                                <tr>
                                    <td><%= attempt.studentName %></td>
                                    <td><%= attempt.score %></td>
                                    <td><%= attempt.totalMarks %></td>
                                    <td><%= attempt.percentage.toFixed(2) %>%</td>
                                    <td><%= new Date(attempt.submittedAt).toLocaleString() %></td>
                                </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            <% } %>
        </section>
    </div>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 QuizMaster. Online Testing System</p>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
