<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title : 'QuizMaster' %> - Online Testing System</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <!-- Navigation Bar -->
    <nav class="navbar">
        <div class="nav-container">
            <div class="nav-brand">
                <h1>📚 QuizMaster</h1>
            </div>
            <ul class="nav-menu">
                <li><a href="/">Home</a></li>
                <% if (user && user.userId) { %>
                    <li><a href="/dashboard">Dashboard</a></li>
                    <li><a href="/leaderboard">Leaderboard</a></li>
                    <% if (user.role === 'admin') { %>
                        <li><a href="/admin/dashboard">Admin Panel</a></li>
                    <% } %>
                    <li><span class="user-name">Hello, <%= user.name %></span></li>
                    <li><a href="/logout" class="logout-btn">Logout</a></li>
                <% } else { %>
                    <li><a href="/login">Login</a></li>
                    <li><a href="/register">Register</a></li>
                <% } %>
            </ul>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <%- body %>
    </main>

    <!-- Footer -->
    <footer class="footer">
        <p>&copy; 2024 QuizMaster. Online Testing System | Group: Muhammad Afzal Kalwar, Ayesha Bibi, Hafsa Kanwal Awan</p>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
